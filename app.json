{
  "expo": {
    "name": "Atlyginimas LT",
    "slug": "atlyginimas-lt",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "atlyginimas",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#080C14"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "lt.atlyginimas.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Programa naudoja kamerą sąskaitoms faktūroms nuskaityti.",
        "NSPhotoLibraryUsageDescription": "Programa naudoja nuotraukų galeriją sąskaitų dokumentams įkelti.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#080C14"
      },
      "package": "lt.atlyginimas.app",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Programa naudoja nuotraukų galeriją sąskaitų dokumentams įkelti.",
          "cameraPermission": "Programa naudoja kamerą sąskaitoms faktūroms nuskaityti."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#4F8EF7"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "2acb6c42-1a82-4d31-83a6-4343fdf6dc35"
      }
    },
    "owner": "atiduok"
  }
}
