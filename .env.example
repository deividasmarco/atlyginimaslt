# Copy this file to ".env" and fill in your real values.
# ".env" is git-ignored and must NEVER be committed.
#
# Optional invoice-scanning service. Leave these empty to disable the
# scan feature. All values are the external service's required request
# format (endpoint, model id, and HTTP header names/values).

EXPO_PUBLIC_SCAN_KEY=
EXPO_PUBLIC_SCAN_ENDPOINT=
EXPO_PUBLIC_SCAN_MODEL=
EXPO_PUBLIC_SCAN_VERSION_HEADER=
EXPO_PUBLIC_SCAN_VERSION=
EXPO_PUBLIC_SCAN_PDF_HEADER=
EXPO_PUBLIC_SCAN_PDF_VALUE=
